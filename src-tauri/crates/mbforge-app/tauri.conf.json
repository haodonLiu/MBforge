{
  "productName": "MBForge",
  "version": "0.3.0",
  "identifier": "com.mbforge.app",
  "build": {
    "frontendDist": "../../../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm --prefix ../../../frontend run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MBForge",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "transparent": false,
        "fullscreen": false,
        "resizable": true
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../../icons/32x32.png",
      "../../icons/128x128.png",
      "../../icons/128x128@2x.png",
      "../../icons/icon.icns",
      "../../icons/icon.ico"
    ]
  }
}
