# ============================================================================
# MBForge Configuration Template
# MBForge 配置模板
# ============================================================================
# English:
#   Usage:
#     cp .env.template .env
#     # Then edit .env and fill in real values
#   `.env` is already in .gitignore — do NOT commit it.
#
#   Loading mechanism:
#     - Rust side loads via `main::load_dotenv()` searching upward from CWD
#     - Python side reads via `os.environ`
#     Both share the same set of environment variables.
#
#   Naming convention:
#     - MBForge-owned variables use the `MBFORGE_` prefix
#     - Third-party service variables (UNIPARSER_*, MINERU_*) keep their
#       official names without prefix, to stay aligned with vendor docs.
#
# 中文:
#   使用方式：
#     cp .env.template .env
#     # 然后编辑 .env，填入真实值
#   `.env` 已加入 .gitignore —— 禁止提交。
#
#   加载机制：
#     - Rust 侧通过 `main::load_dotenv()` 从 CWD 向上查找 `.env`
#     - Python 侧通过 `os.environ` 读取
#     两者共享同一套环境变量。
#
#   命名规范：
#     - MBForge 自有变量统一使用 `MBFORGE_` 前缀
#     - 第三方服务变量（如 UNIPARSER_*、MINERU_*）保持与官方文档一致，不加前缀
# ============================================================================


# ============================================================================
# LLM Configuration (Agent Chat)  /  LLM 配置（Agent 对话）
# ============================================================================
# Purpose: Powers the Agent conversation, tool-use ReAct loop, and most LLM calls.
# 用途:    驱动 Agent 对话、工具调用 ReAct 循环以及绝大部分 LLM 调用。
#
# provider: openai_compatible | anthropic
# base_url examples / 示例:
#   OpenAI:           https://api.openai.com/v1
#   OpenRouter:       https://openrouter.ai/api/v1
#   DeepSeek:         https://api.deepseek.com/v1
#   DashScope (Qwen): https://dashscope.aliyuncs.com/compatible-mode/v1
#   Self-hosted:      http://localhost:8080/v1  (llama.cpp / vLLM / ollama)
#
# CAUTION: Do NOT point base_url at the MBForge sidecar
#          (http://127.0.0.1:18792) — it is NOT an OpenAI-compatible endpoint.
# 注意:  不要把 base_url 指向 MBForge sidecar (http://127.0.0.1:18792)，
#        它不是 OpenAI 兼容端点。
#
# Get API Key  /  申请 API Key:
#   OpenAI:           https://platform.openai.com/api-keys
#   Anthropic:        https://console.anthropic.com/settings/keys
#   OpenRouter:       https://openrouter.ai/settings/keys
#   DeepSeek:         https://platform.deepseek.com/api_keys
#   DashScope (Qwen): https://dashscope.console.aliyun.com/apiKey
# ============================================================================
MBFORGE_LLM_PROVIDER=openai_compatible
MBFORGE_LLM_BASE_URL=
MBFORGE_LLM_API_KEY=
MBFORGE_LLM_MODEL=
MBFORGE_LLM_MAX_TOKENS=4096
MBFORGE_LLM_TEMPERATURE=0.7
MBFORGE_LLM_TOP_P=0.9


# ============================================================================
# Embedding Configuration (Vector Knowledge Base)
# Embedding 配置（向量知识库）
# ============================================================================
# Purpose: Generates 384-dim (or your-model-dim) vectors for chunks stored in
#          .mbforge/knowledge_base/vectors.db; powers hybrid search.
# 用途:    为 .mbforge/knowledge_base/vectors.db 中的 chunk 生成向量
#          （默认 384 维，与所选模型一致）；驱动混合搜索。
#
# EMBED_DIM must match the model's output dimension, otherwise search breaks.
# EMBED_DIM 必须与模型输出维度一致，否则搜索会出错。
#
# Common models  /  常用模型:
#   - BAAI/bge-small-en-v1.5        -> dim 384
#   - BAAI/bge-small-zh-v1.5        -> dim 512
#   - BAAI/bge-base-en-v1.5         -> dim 768
#   - text-embedding-3-small (OpenAI)-> dim 1536
#
# Get API Key  /  申请 API Key: (see LLM section above, same providers)
#   OpenAI:      https://platform.openai.com/api-keys
#   DashScope:   https://dashscope.console.aliyun.com/apiKey
#   Self-hosted: run an OpenAI-compatible embedding server (e.g. llama.cpp,
#                vLLM, ollama, Infinity) and point BASE_URL at it.
# ============================================================================
MBFORGE_EMBED_PROVIDER=openai_compatible
MBFORGE_EMBED_BASE_URL=
MBFORGE_EMBED_API_KEY=
MBFORGE_EMBED_MODEL=
MBFORGE_EMBED_DIM=384


# ============================================================================
# Rerank Configuration (Hybrid Search Re-ranking)
# Rerank 配置（混合搜索重排序）
# ============================================================================
# Purpose: Re-ranks FTS5 + vector recall results before final delivery.
# 用途:    在最终返回前对 FTS5 + 向量召回的结果进行重排序。
#
# Rerank is OPTIONAL — leave API_KEY empty to skip and rely on RRF fusion only.
# Rerank 是可选的 —— 留空 API_KEY 则跳过，仅使用 RRF 融合。
#
# Get API Key  /  申请 API Key:
#   Cohere:         https://dashboard.cohere.com/api-keys
#   Jina AI:        https://jina.ai/dashboard/
#   DashScope (gte-rerank): https://dashscope.console.aliyun.com/apiKey
# ============================================================================
MBFORGE_RERANK_PROVIDER=openai_compatible
MBFORGE_RERANK_BASE_URL=
MBFORGE_RERANK_API_KEY=
MBFORGE_RERANK_MODEL=


# ============================================================================
# VLM Configuration (Molecule Image Recognition / MolScribe)
# VLM 配置（分子图像识别 / MolScribe）
# ============================================================================
# Purpose: Optional Vision-Language Model fallback for molecule image OCR.
#          MolScribe handles most cases locally; VLM is the cloud backup.
# 用途:    可选的视觉-语言模型，用于分子图像 OCR 的云端兜底。
#          MolScribe 在本地处理大多数情况，VLM 作为云端备份。
#
# Get API Key  /  申请 API Key:
#   OpenAI (GPT-4o, GPT-4-vision): https://platform.openai.com/api-keys
#   Anthropic (Claude with vision): https://console.anthropic.com/settings/keys
#   DashScope (Qwen-VL):           https://dashscope.console.aliyun.com/apiKey
# ============================================================================
MBFORGE_VLM_PROVIDER=openai_compatible
MBFORGE_VLM_BASE_URL=
MBFORGE_VLM_API_KEY=
MBFORGE_VLM_MODEL=


# ============================================================================
# Model Cache Directories  /  模型缓存目录
# ============================================================================
# Supports absolute paths or paths starting with `~` (tilde expansion).
# 支持绝对路径或以 `~` 开头的相对路径（自动展开）。
#
# HF_HOME         -> Hugging Face cache (transformers, sentence-transformers)
# MODELSCOPE_CACHE -> ModelScope cache (Chinese mirror, often faster in CN)
# TORCH_HOME      -> PyTorch hub cache (e.g. YOLO weights)
# ============================================================================
MBFORGE_MODEL_CACHE_DIR=~/.cache/mbforge
HF_HOME=~/.cache/huggingface
MODELSCOPE_CACHE=~/.cache/modelscope
TORCH_HOME=~/.cache/torch


# ============================================================================
# UniParser Remote Parsing Service  /  UniParser 远程解析服务
# ============================================================================
# Purpose: Cloud PDF parsing backend (alternative to local PyMuPDF/lopdf).
# 用途:    云端 PDF 解析后端（本地 PyMuPDF/lopdf 之外的备选）。
#
# Third-party variables: keep official names (no MBFORGE_ prefix) per vendor docs.
# 第三方变量: 按官方文档命名（不加 MBFORGE_ 前缀）。
#
# Get API Key  /  申请 API Key: https://uniparser.dp.tech/
#   1. Visit the URL above / 访问上述网址
#   2. Register & verify account / 注册并完成认证
#   3. Open the console dashboard / 进入控制台
#   4. Create a new API key / 创建新的 API key
#   5. Copy the key into UNIPARSER_API_KEY below / 复制到下方 UNIPARSER_API_KEY
#
# Docs / 文档: https://uniparser.dp.tech/
# ============================================================================
UNIPARSER_HOST=https://uniparser.dp.tech/
UNIPARSER_API_KEY=


# ============================================================================
# MinerU Document Parsing  /  MinerU 文档解析
# ============================================================================
# Purpose: Open-source document parsing service (PDF, images, tables).
# 用途:    开源文档解析服务（PDF、图像、表格）。
#
# Third-party variables: keep official names (no MBFORGE_ prefix) per vendor docs.
# 第三方变量: 按官方文档命名（不加 MBFORGE_ 前缀）。
#
# Get API Key  /  申请 API Key: https://mineru.net
#   1. Visit https://mineru.net / 访问 https://mineru.net
#   2. Sign up & log in / 注册并登录
#   3. Open the "API Key" page in the user center / 进入用户中心的"API Key"页
#   4. Click "Create" and copy the key / 点击"创建"并复制密钥
#
# Docs / 文档: https://mineru.net/apiManage/docs
# ============================================================================
MINERU_HOST=https://mineru.net
MINERU_API_KEY=


# ============================================================================
# DeepXiv (Academic Paper Search)  /  DeepXiv（学术论文检索）
# ============================================================================
# Purpose: Agent tool for searching arXiv / bioRxiv / medRxiv papers.
# 用途:    Agent 工具，用于检索 arXiv / bioRxiv / medRxiv 论文。
#
# Note: DeepXiv CLI auto-registers a token on first use — you can leave this
#       empty and the SDK will provision one automatically. Fill it manually
#       only if you have a pre-issued key from the dashboard.
# 注意:  DeepXiv CLI 在首次使用时自动注册 token —— 可以留空，SDK 会自动
#        分配一个。仅当你在控制台拿到了预签发的 key 时才需要手动填写。
#
# Third-party variables: keep official names (no MBFORGE_ prefix) per vendor docs.
# 第三方变量: 按官方文档命名（不加 MBFORGE_ 前缀）。
#
# Get API Key / Dashboard  /  申请 API Key / 控制台:
#   https://data.rag.ac.cn/api/docs
#   https://github.com/DeepXiv/deepxiv_sdk
#
# Install  /  安装: pip install deepxiv-sdk
# ============================================================================
DEEPXIV_API_KEY=
