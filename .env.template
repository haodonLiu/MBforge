# ============================================================================
# UniParser 远程解析服务
# ============================================================================
UNIPARSER_HOST=https://uniparser.dp.tech  # UniParser API 基础地址（文档页面在 /api）
UNIPARSER_API_KEY=

# ============================================================================
# MinerU 文档解析服务（https://mineru.net）
# ============================================================================
# Agent API: 无需 Token，IP 限流，适合临时使用
# Precise API: 需 JWT Token，支持 zip 下载，质量更高
# 留空 API_KEY 则自动使用 Agent API
MINERU_HOST=https://mineru.net
MINERU_API_KEY=

# ============================================================================
# MBForge LLM / AI 模型配置
# 优先级：GUI设置 > 环境变量 > 默认值
# ============================================================================

# ---------- LLM 大语言模型 ----------
# Provider: openai_compatible | anthropic | ollama
MBFORGE_LLM_PROVIDER=openai_compatible
# API 基础地址
# 硅基流动:   https://api.siliconflow.cn/v1
# MiniMax:    https://api.minimaxi.com/anthropic
# 本地 vLLM:  http://localhost:8000/v1
# Ollama:     http://localhost:11434/v1
MBFORGE_LLM_BASE_URL=https://api.siliconflow.cn/v1
MBFORGE_LLM_API_KEY=
MBFORGE_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
MBFORGE_LLM_MAX_TOKENS=4096
MBFORGE_LLM_TEMPERATURE=0.7
MBFORGE_LLM_TOP_P=0.9

# ---------- Embedding 文本向量模型 ----------
# Provider: sentence_transformers | api
# 推荐模型: BAAI/bge-small-zh-v1.5, Qwen/Qwen3-Embedding-0.6B
MBFORGE_EMBED_PROVIDER=sentence_transformers
MBFORGE_EMBED_MODEL=BAAI/bge-small-zh-v1.5
MBFORGE_EMBED_DEVICE=cpu
# API 模式时填写
# MBFORGE_EMBED_BASE_URL=
# MBFORGE_EMBED_API_KEY=

# ---------- Rerank 重排序模型 ----------
# 推荐模型: BAAI/bge-reranker-base, Qwen/Qwen3-Reranker-0.6B
MBFORGE_RERANK_MODEL=BAAI/bge-reranker-base
MBFORGE_RERANK_DEVICE=cpu

# ---------- VLM 视觉语言模型（可选） ----------
# MBFORGE_VLM_PROVIDER=api
# MBFORGE_VLM_BASE_URL=
# MBFORGE_VLM_API_KEY=
# MBFORGE_VLM_MODEL=

# ============================================================================
# MBForge 运行时配置
# ============================================================================

# Sidecar URL（Python 模型服务地址，默认 http://127.0.0.1:18792）
# MBFORGE_SIDECAR_URL=http://127.0.0.1:18792

# 禁止 Tauri 自动启动 Python sidecar（开发模式用，默认 0）
# MBFORGE_NO_SPAWN=1

# 强制使用 CPU 推理（忽略 GPU 检测）
# MBFORGE_FORCE_CPU=1

# 日志级别
# MBFORGE_LOG_LEVEL=INFO

# MolScribe 模型缓存目录
# MBFORGE_MOLSCRIBE_DIR=

# ============================================================================
# 模型缓存目录（可选，默认为各库系统缓存目录）
# ============================================================================
# HuggingFace 模型缓存（sentence-transformers、transformers 等）
HF_HOME=~/Models/HuggingFace

# ModelScope 模型缓存
MODELSCOPE_CACHE=~/Models/ModelScope

# Ollama 本地模型存放目录
OLLAMA_MODELS=~/Models/Ollama

# PyTorch 模型/权重缓存
TORCH_HOME=~/Models/Torch

# ============================================================================
# UV 包管理器镜像配置
# ============================================================================
UV_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
UV_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn
UV_PYTHON_MIRRORS=https://mirror.sjtu.edu.cn/python-request
