# ============================================================================
# MBForge configuration template
# ============================================================================
# Copy this file to `.env` and fill in the real values.
#   cp .env.template .env
# `.env` is in .gitignore — never commit it.
#
# `main::load_dotenv()` walks up from the CWD looking for `.env` and injects
# every `KEY=VALUE` line into the process env, so any of these variables are
# visible to both the Rust core (via `std::env::var`) and the Python sidecar
# (via `os.environ`).
#
# Naming convention: every project-owned env var uses the `MBFORGE_` prefix
# (e.g. `MBFORGE_LLM_*`, `MBFORGE_SIDECAR_URL`, `MBFORGE_MODEL_CACHE_DIR`).
# The MBForge-owned keys live alongside third-party service keys
# (`UNIPARSER_*`, `MINERU_*`, `DEEPXIV_*`) that map 1:1 to the vendor's own
# service URL/API-key convention.
# ============================================================================


# ============================================================================
# LLM — OpenAI-compatible (or Anthropic) endpoint used by the rig-core
# integration in `core/agent/rig_adapter.rs`.
# ============================================================================
# Required: provider is auto-detected from the API shape (OpenAI-compatible
# vs Anthropic) via the existing `llm.provider` field in
# `~/.config/MBForge/config.json`. The values below are read by
# `MbforgeProviderConfig::from_app_config()` and override whatever is in
# config.json — config.json is the fallback for advanced users only.
#
# base_url examples:
#   https://api.openai.com/v1
#   https://openrouter.ai/api/v1
#   https://api.deepseek.com/v1
#   http://localhost:8080/v1       (self-hosted llama.cpp / vLLM / ollama)
#
# DO NOT point this at the MBForge sidecar (http://127.0.0.1:18792/v1) —
# the sidecar is not an OpenAI-compatible endpoint.
MBFORGE_LLM_PROVIDER=openai_compatible
MBFORGE_LLM_BASE_URL=
MBFORGE_LLM_API_KEY=
MBFORGE_LLM_MODEL=
MBFORGE_LLM_MAX_TOKENS=4096
MBFORGE_LLM_TEMPERATURE=0.7
MBFORGE_LLM_TOP_P=0.9


# ============================================================================
# UniParser 远程解析服务 (https://uniparser.dp.tech/)
# Third-party vendor keys — kept unprefixed to match the vendor's docs.
# ============================================================================
UNIPARSER_HOST=https://uniparser.dp.tech/
UNIPARSER_API_KEY=


# ============================================================================
# MinerU (https://mineru.net)
# Third-party vendor keys — kept unprefixed to match the vendor's docs.
# ============================================================================
MINERU_HOST=https://mineru.net
MINERU_API_KEY=


# ============================================================================
# DeepXiv
# Third-party vendor keys — kept unprefixed to match the vendor's docs.
# ============================================================================
DEEPXIV_API_KEY=
