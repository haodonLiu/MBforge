# UniParser Configuration
UNIPARSER_HOST=https://your-uniparser-server.com
UNIPARSER_API_KEY=your-api-key-here

# ============================================================================
# MBForge LLM / AI 模型配置
# 支持通过 .env 文件或 GUI 设置面板配置
# 优先级：GUI设置 > 环境变量 > 默认值
# ============================================================================

# ---------- LLM 大语言模型 ----------
# Provider: openai_compatible | local | ollama
MBFORGE_LLM_PROVIDER=openai_compatible
# API 基础地址（兼容 OpenAI 格式）
# 示例：硅基流动 https://api.siliconflow.cn/v1
# 示例：本地 vLLM http://localhost:8000/v1
# 示例：Ollama http://localhost:11434/v1
MBFORGE_LLM_BASE_URL=https://api.siliconflow.cn/v1
MBFORGE_LLM_API_KEY=your-llm-api-key-here
MBFORGE_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
MBFORGE_LLM_MAX_TOKENS=4096
MBFORGE_LLM_TEMPERATURE=0.7
MBFORGE_LLM_TOP_P=0.9

# ---------- Embedding 文本向量模型 ----------
# Provider: sentence_transformers | openai | api
MBFORGE_EMBED_PROVIDER=sentence_transformers
MBFORGE_EMBED_MODEL=BAAI/bge-small-zh-v1.5
MBFORGE_EMBED_DEVICE=cpu
# 如果使用 API 提供 embedding，填写以下两项
# MBFORGE_EMBED_BASE_URL=
# MBFORGE_EMBED_API_KEY=

# ---------- Rerank 重排序模型 ----------
MBFORGE_RERANK_MODEL=BAAI/bge-reranker-base
MBFORGE_RERANK_DEVICE=cpu

# ---------- VLM 视觉语言模型（可选） ----------
# MBFORGE_VLM_PROVIDER=api
# MBFORGE_VLM_BASE_URL=
# MBFORGE_VLM_API_KEY=
# MBFORGE_VLM_MODEL=
